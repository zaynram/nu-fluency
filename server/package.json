{
  "name": "nushell-mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol server exposing queryable Nushell documentation and a Nushell execution environment.",
  "type": "module",
  "bin": "./build/index.js",
  "scripts": {
    "start": "bun ./build/index.js",
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=build",
    "test": "bun test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nushell",
    "nu",
    "shell",
    "documentation"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "bun-types": "^1.3.14",
    "typescript": "^5.0.0"
  }
}
